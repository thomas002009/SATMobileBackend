// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())

  lists    WordList[]
  progress UserWordProgress[]
}

model WordList {
  id          String   @id @default(uuid())
  title       String
  description String?
  isPublic    Boolean  @default(false) // for shared lists
  isAdmin     Boolean  @default(false) // marks pre-built/curated lists
  createdAt   DateTime @default(now())

  ownerId String?
  owner   User?   @relation(fields: [ownerId], references: [id])

  words Word[]
}

model Word {
  id         String   @id @default(uuid())
  term       String
  definition String
  example    String? // optional example sentence
  createdAt  DateTime @default(now())

  listId String
  list   WordList @relation(fields: [listId], references: [id])

  progress UserWordProgress[]
}

// Tracks per-user memorization progress on each word
model UserWordProgress {
  id          String    @id @default(uuid())
  userId      String
  wordId      String
  mastered    Boolean   @default(false)
  reviewCount Int       @default(0)
  lastReview  DateTime?

  user User @relation(fields: [userId], references: [id])
  word Word @relation(fields: [wordId], references: [id])

  @@unique([userId, wordId])
}
